# Brikko Studio — local docker-compose env (managed by brikko-cli).
#
# Edited by `brikko init` on first run. You can hand-edit this file too —
# `brikko start` / `brikko update` will read it as-is.

# Brikko Gateway base URL the Studio talks to (production by default).
BRIKKO_GATEWAY=https://api.brikko.ru

# Host port the Studio UI / OAuth callback listens on.
BRIKKO_PORT=3737

# Set to 1 if libsecret/Keychain is not available on the host (e.g. headless CI).
# In that case the oauth-client falls back to an in-memory keychain.
BRIKKO_USE_INMEM_KEYCHAIN=0

# Anonymizer sidecar port (host-side mapping, bound to 127.0.0.1).
ANONYMIZER_PORT=8403

# Redis port (host-side mapping, bound to 127.0.0.1).
REDIS_PORT=6379

# Image tag for ghcr.io/brikkoai/studio-{core,anonymizer}.
# Use `brikko update` to pull the newest images.
BRIKKO_VERSION=latest
